{
  "name": "inventory-management-server",
  "version": "1.0.0",
  "description": "Express + TypeScript backend for inventory management",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs'); const path=require('path'); const src=path.join('src','utils','swagger.yaml'); const dest=path.join('dist','utils'); fs.mkdirSync(dest,{recursive:true}); fs.copyFileSync(src,path.join(dest,'swagger.yaml'));\"",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.43.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.4",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.3",
    "react-icons": "^5.6.0",
    "swagger-ui-express": "^4.6.3",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.14.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
